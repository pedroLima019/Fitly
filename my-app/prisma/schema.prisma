// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  personal
  student
}

enum RequestStatus {
  pending
  accepted
  rejected
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  userType      UserType? // "personal" ou "student"
  specialties   String?
  location      String?   // Mantém pela compatibilidade, pode ser removido depois
  bio           String?
  hourlyRate    Float?
  pricePerSession Float?
  goal          String?
  trainingLevel String?
  availability  String?
  workoutPlace  String?
  limitations   String?
  
  // Endereço detalhado
  street        String?
  number        String?
  complement    String?
  city          String?
  state         String?
  zipCode       String?
  country       String?   @default("Brasil")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  // Relacionamentos
  trainings        Training[]
  requestsSent     ClientRequest[] @relation("StudentRequests")
  requestsReceived ClientRequest[] @relation("PersonalRequests")
  students         PersonalStudent[] @relation("PersonalToStudents")
  personals        PersonalStudent[] @relation("StudentToPersonals")
  
  // Mensagens
  sentMessages                  Message[] @relation("SentMessages")
  personalChatConnections       Message[] @relation("PersonalInChat")
  studentChatConnections        Message[] @relation("StudentInChat")
}

model Training {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exercise {
  id        String   @id @default(cuid())
  name      String
  sets      Int
  reps      Int
  weight    Float?
  trainingId String
  training  Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientRequest {
  id        String   @id @default(cuid())
  studentId  String
  personalId String
  student    User     @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  personal   User     @relation("PersonalRequests", fields: [personalId], references: [id], onDelete: Cascade)
  message   String
  status    RequestStatus @default(pending) // "pending", "accepted", "rejected"
  deletedAt DateTime? // soft delete para auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, personalId])
}

model PersonalStudent {
  id         String   @id @default(cuid())
  studentId  String
  personalId String
  createdAt  DateTime @default(now())

  student  User @relation("StudentToPersonals", fields: [studentId], references: [id], onDelete: Cascade)
  personal User @relation("PersonalToStudents", fields: [personalId], references: [id], onDelete: Cascade)

  @@unique([studentId, personalId])
}

model Message {
  id          String    @id @default(cuid())
  
  // Participantes da conversa
  personalId  String
  studentId   String
  personal    User      @relation("PersonalInChat", fields: [personalId], references: [id], onDelete: Cascade)
  student     User      @relation("StudentInChat", fields: [studentId], references: [id], onDelete: Cascade)
  
  // Quem enviou
  senderId    String
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  // Conteúdo
  content     String
  
  // Status de leitura
  readAt      DateTime?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Índices para performance
  @@index([personalId, studentId])
  @@index([createdAt])
}

